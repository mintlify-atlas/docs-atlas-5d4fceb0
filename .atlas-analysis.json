  "keyFeatures": [
    "1000+ pre-built tool integrations (GitHub, Gmail, Slack, Notion, and more)",
    "Managed OAuth2, API key, and Bearer token authentication for users",
    "Session-scoped tool execution with per-user isolation",
    "MCP (Model Context Protocol) server endpoint per session",
    "Sandboxed remote workbench with bash execution",
    "Tool Router for intelligent context-aware tool selection",
    "Real-time triggers and webhook event handling",
    "Custom tool and custom toolkit creation",
    "File upload/download handling during tool execution",
    "Provider adapters for OpenAI, Anthropic, LangChain, Vercel AI SDK, Google, CrewAI, Mastra, LlamaIndex",
    "Composio CLI for terminal-based tool execution inside Claude Code"
  ],
  "publicApiSurface": [
    "new Composio({ apiKey, provider, ... })",
    "composio.tools.get(userId, { toolkits, tools, tags })",
    "composio.tools.execute(toolSlug, { userId, arguments })",
    "composio.toolkits.get(toolkit)",
    "composio.toolkits.list()",
    "composio.connectedAccounts.get(connectedAccountId)",
    "composio.connectedAccounts.list({ userId })",
    "composio.connectedAccounts.initiate({ userId, toolkitSlug, ... })",
    "composio.authConfigs.create({ toolkitSlug, authScheme, credentials })",
    "composio.triggers.subscribe(userId, { toolkitSlug, triggerSlug, callback })",
    "composio.mcp.get(mcpUrl, userId)",
    "composio.create(userId) → Session",
    "session.tools()",
    "session.mcp.url",
    "session.authorize({ toolkitSlug, callbackUrl })",
    "experimental_createTool(config)",
    "experimental_createToolkit(config)",
    "OpenAIProvider, AnthropicProvider, LangChainProvider, VercelProvider, GoogleProvider, MastraProvider",
    "composio login / whoami / search / execute / link / proxy / run (CLI commands)"
  ]
